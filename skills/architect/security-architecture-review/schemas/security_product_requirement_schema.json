{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Security Product Requirements",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "requirements"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "requirement_id",
          "title",
          "statement",
          "linked_scenarios",
          "linked_findings",
          "priority",
          "owner",
          "target_milestone",
          "status",
          "acceptance_criteria",
          "last_reviewed_at"
        ],
        "properties": {
          "requirement_id": {
            "type": "string",
            "pattern": "^SPR-[0-9]{3,}$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "statement": {
            "type": "string",
            "minLength": 10
          },
          "linked_scenarios": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^AS-[0-9]{2,}$"
            },
            "minItems": 1
          },
          "linked_findings": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "owner": {
            "type": "string"
          },
          "target_milestone": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "planned",
              "in_progress",
              "blocked",
              "done",
              "deferred",
              "accepted-risk"
            ]
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "verification_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_reviewed_at": {
            "type": "string",
            "format": "date"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
